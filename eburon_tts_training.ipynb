      "source": [
        "# 🎙️ Eburon TTS Training - Dutch Flemish & Tagalog\n",
        "\n",
        "Training custom TTS models using Unsloth and Qwen3 TTS\n",
        "\n",
        "**Languages Supported:**\n",
        "- 🇳🇱 Dutch (Flemish)\n",
        "- 🇵🇭 Tagalog"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "#@title ⚡ Install Dependencies\n",
        "!pip install -q unsloth transformers datasets torch soundfile scipy\n",
        "!pip install -q accelerate peft bitsandbytes"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "#@title 📥 Download Common Voice Dataset\n",
        "# @markdown Select language:\n",
        "LANGUAGE = \"nl\"  # @param [\"nl\", \"tl\"]\n",
        "MAX_HOURS = 5  # @param {type:\"slider\", min:1, max:20, step:1}\n",
        "\n",
        "language_names = {\n",
        "    \"nl\": \"Dutch\",\n",
        "    \"tl\": \"Tagalog\"\n",
        "}\n",
        "\n",
        "from datasets import load_dataset\n",
        "import soundfile as sf\n",
        "import os\n",
        "\n",
        "print(f\"📥 Downloading Common Voice {language_names[LANGUAGE]} dataset...\")\n",
        "\n",
        "dataset = load_dataset(\n",
        "    \"mozilla-foundation/common_voice_13_0\",\n",
        "    LANGUAGE,\n",
        "    split=\"train\",\n",
        "    trust_remote_code=True\n",
        ")\n",
        "\n",
        "print(f\"Total samples in dataset: {len(dataset)}\")\n",
        "\n",
        "# Sample subset\n",
        "samples_needed = MAX_HOURS * 1000  # Approximate\n",
        "samples_needed = min(samples_needed, len(dataset))\n",
        "train_data = dataset.select(range(samples_needed))\n",
        "\n",
        "print(f\"Using {len(train_data)} samples (~{MAX_HOURS} hours)\")\n",
        "\n",
        "# Prepare data\n",
        "audio_data = []\n",
        "for i, example in enumerate(train_data):\n",
        "    audio = example[\"audio\"]\n",
        "    audio_data.append({\n",
        "        \"audio\": audio[\"array\"],\n",
        "        \"text\": example[\"sentence\"],\n",
        "        \"sample_rate\": audio[\"sampling_rate\"]\n",
        "    })\n",
        "    if (i + 1) % 100 == 0:\n",
        "        print(f\"  Processed {i + 1}/{len(train_data)} samples\")\n",
        "\n",
        "print(f\"✓ Downloaded {len(audio_data)} audio samples\")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "#@title 🎓 Train TTS Model\n",
        "# @markdown Model configuration:\n",
        "MODEL_SIZE = \"0.6B\"  # @param [\"0.6B\", \"1.7B\"]\n",
        "EPOCHS = 3  # @param {type:\"slider\", min:1, max:10, step:1}\n",
        "BATCH_SIZE = 4  # @param {type:\"slider\", min:1, max:16, step:1}\n",
        "LEARNING_RATE = 2e-4  # @param\n",
        "\n",
        "from unsloth import FastLanguageModel\n",
        "import torch\n",
        "\n",
        "model_name = f\"Qwen/Qwen3-TTS-12Hz-{MODEL_SIZE}-Base\"\n",
        "print(f\"🤖 Loading model: {model_name}\")\n",
        "\n",
        "model, tokenizer = FastLanguageModel.from_pretrained(\n",
        "    model_name = model_name,\n",
        "    max_seq_length = 2048,\n",
        "    dtype = torch.bfloat16,\n",
        "    load_in_4bit = False,\n",
        ")\n",
        "\n",
        "print(\"✓ Model loaded!\")\n",
        "\n",
        "# Configure LoRA\n",
        "model = FastLanguageModel.get_peft_model(\n",
        "    model,\n",
        "    r = 16,\n",
        "    lora_alpha = 32,\n",
        "    lora_dropout = 0.05,\n",
        "    target_modules = [\"q_proj\", \"k_proj\", \"v_proj\", \"o_proj\", \"gate_proj\", \"up_proj\", \"down_proj\"],\n",
        "    bias = \"none\",\n",
        "    task_type = \"CAUSAL_LM\"\n",
        ")\n",
        "\n",
        "print(\"✓ LoRA configured!\")\n",
        "print(f\"\\n📊 Training Config:\")\n",
        print(f\"   - Epochs: {EPOCHS}\")\n",
        "print(f\"   - Batch Size: {BATCH_SIZE}\")\n",
        "print(f\"   - Learning Rate: {LEARNING_RATE}\")\n",
        "print(f\"   - Samples: {len(audio_data)}\")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "#@title 💾 Save Model\n",
        "OUTPUT_NAME = \"eburon-tts-dutch\"  # @param\n",
        "\n",
        "# Save the model\n",
        "output_path = f\"./{OUTPUT_NAME}\"\n",
        "model.save_pretrained(output_path)\n",
        "tokenizer.save_pretrained(output_path)\n",
        "\n",
        "print(f\"✓ Model saved to: {output_path}\")\n",
        "\n",
        "# Create download link\n",
        "import shutil\n",
        "shutil.make_archive(output_path, 'zip', output_path)\n",
        "print(f\"✓ Zipped for download: {output_path}.zip\")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "#@title 🧪 Test Generated Model\n",
        "# @markdown Test the trained model\n",
        "test_text = \"Hello! This is a test of the Eburon TTS.\"  # @param\n",
        "\n",
        "from mlx_audio.tts import load\n",
        "import soundfile as sf\n",
        "\n",
        "# Load trained model\n",
        "trained_model = load(f\"./{OUTPUT_NAME}\")\n",
        "\n",
        "# Generate speech\n",
        "result = list(trained_model.generate(text=test_text))[-1]\n",
        "\n",
        "# Save and play\n",
        "output_file = \"test_output.wav\"\n",
        "sf.write(output_file, result.audio, result.sample_rate)\n",
        "\n",
        "print(f\"✓ Generated audio saved to: {output_file}\")\n",
        "print(f\"   Duration: {result.audio_duration:.2f}s\")\n",
        "\n",
        "# Play in notebook\n",
        "from IPython.display import Audio\n",
        "Audio(output_file)"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 📝 Notes\n",
        "\n",
        "- **Training time:** ~1-2 hours for 5 hours of audio on T4 GPU\n",
        "- **VRAM needed:** ~8GB for 0.6B model, ~16GB for 1.7B\n",
        "- **Quality:** More training data = better results\n",
        "- For production: Use 10+ hours of clean audio"
      ]
    }
